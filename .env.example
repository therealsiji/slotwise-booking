# Supabase Postgres
# Get these from Supabase Dashboard > Project Settings > Database.
#
# Runtime connection. Use Supabase Transaction Pooler for serverless/dev runtime.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Migration connection. Use Supabase Direct connection or Session Pooler.
# Prisma CLI commands prefer this when present.
DATABASE_DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase project API settings.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

RESEND_API_KEY=""
EMAIL_FROM="SlotWise <appointments@example.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
